# prepack stash (restored by postpack; transient)
.publish-stash/

# npm pack output
omp-deck-*.tgz

node_modules
dist
.DS_Store
.env
.env.local
*.log
.bun
.vite

# Build artifacts
apps/*/dist
apps/web/dist-server
.next

# Editor
.vscode
.idea
*.swp
# Runtime + deck-managed data
apps/server/data
apps/server/data/*.db
apps/server/data/*.db-shm
apps/server/data/*.db-wal
apps/server/dist-server
apps/bridges/*/dist

# Smoke / spawn helpers and captured logs
.logs
.deck-data
orgd-stdout.log
vite.err.log
vite.out.log
server.err.log
server.out.log

# Local config the deck or bridges may write
.env.*
!.env.example

# Dev-process screenshot scratch dir (the curated set lives in docs/screenshots/)
/screenshots

# TypeScript incremental build cache
*.tsbuildinfo

# Local-only routine templates. Anything matching this glob is treated as a
# private template — the install endpoint still picks it up at runtime, but
# it never lands in the public repo. Author shipped templates without the
# `local.` prefix or under any other name.
apps/server/src/templates/paper-trading-*.yaml

# Local convenience scripts. Start-OMP-Deck.cmd ships with the template;
# personal helpers like Restart-OMP-Deck.cmd stay out of the public repo.
Restart-OMP-Deck.cmd
